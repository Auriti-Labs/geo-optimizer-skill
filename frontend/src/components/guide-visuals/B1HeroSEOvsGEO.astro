  <!-- Line 1 -->
  <rect x="506" y="103" width="178" height="4" rx="2" fill="#CBD5E1"/>
  <!-- Line 2 -->
  <rect x="506" y="112" width="162" height="4" rx="2" fill="#CBD5E1"/>
  <!-- Line 3 -->
  <rect x="506" y="121" width="174" height="4" rx="2" fill="#CBD5E1"/>
