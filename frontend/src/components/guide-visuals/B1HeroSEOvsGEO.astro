  <rect x="374" y="98" width="32" height="22" fill="#FFFFFF" rx="4"/>
  <text x="390" y="114" text-anchor="middle" font-family="system-ui, -apple-system, sans-serif" font-size="12" font-weight="700" fill="#94A3B8">vs</text>

