---
/**
 * LlmsPreview — a real, borderless preview of a generated llms.txt file as a
 * styled text surface (not a screenshot). Reads like the actual artifact.
 */
interface Props {
  variant?: 'dark' | 'light';
  class?: string;
}
const { variant = 'dark', class: className = '' } = Astro.props;
const isDark = variant === 'dark';
const ink = isDark ? 'text-slate-200' : 'text-text-secondary';
const muted = isDark ? 'text-slate-500' : 'text-text-muted';
const h = isDark ? 'text-white' : 'text-text-primary';
const link = 'text-accent-teal';

const lines = [
  { t: 'h1', s: '# Example Co' },
  { t: 'q', s: '> AI visibility tools and guides for modern teams.' },
  { t: 'gap', s: '' },
  { t: 'h2', s: '## Pages' },
  { t: 'li', s: '- [Home](https://example.com/)' },
  { t: 'li', s: '- [Pricing](https://example.com/pricing/)' },
  { t: 'gap', s: '' },
  { t: 'h2', s: '## Guides' },
  { t: 'li', s: '- [What is llms.txt](https://example.com/guides/llms-txt/)' },
  { t: 'li', s: '- [AI SEO basics](https://example.com/guides/ai-seo/)' },
];
---

<div class={`relative ${className}`}>
  <div aria-hidden="true" class="pointer-events-none absolute -inset-10 -z-10 rounded-[40px] bg-accent-teal/12 blur-3xl"></div>

  <div class={`overflow-hidden rounded-[--radius-lg] ${isDark ? 'bg-[#0b1320]' : 'bg-bg-surface'}`}>
    <div class={`flex items-center justify-between border-b ${isDark ? 'border-white/8' : 'border-border'} px-4 py-2.5`}>
      <span class={`font-mono text-xs ${h}`}>llms.txt</span>
      <span class={`font-mono text-[10px] uppercase tracking-[0.16em] ${muted}`}>generated</span>
    </div>
    <pre class={`overflow-x-auto px-4 py-4 font-mono text-[13px] leading-relaxed ${ink}`}><code>{lines.map((l) => (
        l.t === 'gap'
          ? <div>&nbsp;</div>
          : <div class={l.t === 'h1' ? `font-semibold ${h}` : l.t === 'h2' ? `font-semibold ${h}` : l.t === 'q' ? muted : l.t === 'li' ? '' : ''}>{l.t === 'li' ? <><span class={muted}>- </span><span class={link}>{l.s.replace(/^- /, '')}</span></> : l.s}</div>
      ))}</code></pre>
  </div>
</div>
