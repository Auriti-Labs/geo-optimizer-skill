---
import { sanityClient } from 'sanity:client';
import { defineQuery } from 'groq';
import { PortableText } from 'astro-portabletext';
import Shell from '../../components/Shell.astro';
import NewsletterSignup from '../../components/NewsletterSignup';

// ── Static paths ──────────────────────────────────────────────────────────────
export async function getStaticPaths() {
  const SLUGS_QUERY = defineQuery(
    `*[_type == "article" && category == "guides" && defined(slug.current) && !coalesce(noindex, false)]{
      "params": { "slug": slug.current }
    }`
  );
  return sanityClient.fetch(SLUGS_QUERY);
}

// ── Fetch article ─────────────────────────────────────────────────────────────
const ARTICLE_QUERY = defineQuery(
  `*[_type == "article" && slug.current == $slug][0]{
    _id, title, metaTitle, slug, description, category,
    datePublished, dateModified, body, faqs,
    ogImage{ asset, alt }, focusKeyword, llmsContext,
    schemaOrgType, author, noindex
  }`
);

const { slug } = Astro.params;
const article = await sanityClient.fetch(ARTICLE_QUERY, { slug });

if (!article) return Astro.redirect('/404', 301);

const canonical = `https://geoready.dev/guides/${slug}/`;
const title = article.metaTitle || article.title;
const schemaType = article.schemaOrgType || 'Article';
const author = article.author || 'Juan Camilo Auriti';

// ── Portable Text custom components ──────────────────────────────────────────
const ptComponents = {
  types: {
    callout: ({ node }: any) => {
      const colors: Record<string, string> = {
        info: 'border-accent-teal/30 bg-accent-teal/5 text-accent-teal',
        tip: 'border-green-400/30 bg-green-400/5 text-green-400',
        warning: 'border-yellow-400/30 bg-yellow-400/5 text-yellow-400',
        stat: 'border-accent-teal/40 bg-accent-teal/8 text-accent-teal',
      };
      const cls = colors[node.variant] || colors.info;
      return `<div class="rounded-xl border ${cls} p-5 my-6"><p class="text-sm leading-relaxed text-text-secondary">${node.body}</p></div>`;
    },
    codeBlock: ({ node }: any) =>
      `<pre class="rounded-xl bg-bg-surface border border-border p-4 my-6 overflow-x-auto text-sm font-mono"><code class="language-${node.language || 'text'}">${node.code}</code></pre>`,
    image: ({ node }: any) => {
      const alt = node.alt || '';
      const caption = node.caption || '';
      return `<figure class="my-8">
        <img src="https://cdn.sanity.io/images/uvzrnk4t/production/${node.asset?._ref?.replace('image-', '').replace(/-([a-z]+)$/, '.$1') || ''}" alt="${alt}" class="rounded-xl w-full" loading="lazy" />
        ${caption ? `<figcaption class="mt-2 text-xs text-text-muted text-center">${caption}</figcaption>` : ''}
      </figure>`;
    },
  },
  block: {
    h2: ({ children }: any) =>
      `<h2 class="font-display text-2xl font-bold text-text-primary leading-tight tracking-tight mt-12 mb-4">${children}</h2>`,
    h3: ({ children }: any) =>
      `<h3 class="font-display text-lg font-semibold text-text-primary mt-8 mb-3">${children}</h3>`,
    h4: ({ children }: any) =>
      `<h4 class="font-semibold text-text-primary mt-6 mb-2">${children}</h4>`,
    normal: ({ children }: any) =>
      `<p class="text-text-secondary leading-relaxed mt-4">${children}</p>`,
    blockquote: ({ children }: any) =>
      `<blockquote class="border-l-4 border-accent-teal pl-4 italic text-text-secondary my-6">${children}</blockquote>`,
  },
  list: {
    bullet: ({ children }: any) =>
      `<ul class="list-disc pl-5 space-y-2 mt-4 text-text-secondary">${children}</ul>`,
    number: ({ children }: any) =>
      `<ol class="list-decimal pl-5 space-y-2 mt-4 text-text-secondary">${children}</ol>`,
  },
  marks: {
    strong: ({ children }: any) => `<strong class="font-semibold text-text-primary">${children}</strong>`,
    em: ({ children }: any) => `<em>${children}</em>`,
    code: ({ children }: any) =>
      `<code class="text-sm font-mono bg-bg-surface border border-border rounded px-1 py-0.5">${children}</code>`,
    link: ({ children, value }: any) => {
      const href = value?.href || '#';
      const isExternal = href.startsWith('http');
      return `<a href="${href}" ${isExternal ? 'target="_blank" rel="noopener noreferrer"' : ''} class="text-accent-teal hover:underline">${children}</a>`;
    },
  },
};

// ── JSON-LD ───────────────────────────────────────────────────────────────────
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': schemaType,
      '@id': `${canonical}#article`,
      url: canonical,
      headline: article.title,
      description: article.description,
      datePublished: article.datePublished,
      dateModified: article.dateModified,
      author: { '@type': 'Person', name: author, url: 'https://geoready.dev/about/' },
      publisher: {
        '@type': 'Organization',
        name: 'GeoReady',
        url: 'https://geoready.dev',
        logo: { '@type': 'ImageObject', url: 'https://geoready.dev/icon-512.png' },
      },
      mainEntityOfPage: canonical,
      isPartOf: { '@id': 'https://geoready.dev/#website' },
    },
    ...(article.faqs?.length
      ? [{
          '@type': 'FAQPage',
          mainEntity: article.faqs.map((faq: any) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: { '@type': 'Answer', text: faq.answer },
          })),
        }]
      : []),
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'GeoReady', item: 'https://geoready.dev/' },
        { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://geoready.dev/guides/' },
        { '@type': 'ListItem', position: 3, name: article.title, item: canonical },
      ],
    },
  ],
};
---

<Shell
  title={title}
  description={article.description}
  canonical={canonical}
  robots={article.noindex ? 'noindex, follow' : 'index, follow'}
>
  <article class="max-w-7xl mx-auto px-4 sm:px-6 py-10 md:py-16" itemscope itemtype="https://schema.org/Article">
    {/* ── Header ──────────────────────────────────────────────────────────── */}
    <header class="mb-12 md:mb-16 max-w-3xl">
      <div class="flex items-center gap-2 text-[10px] font-mono text-text-muted uppercase tracking-wider">
        <a href="/guides/" class="hover:text-accent-teal">Guides</a>
        <span class="w-1 h-1 rounded-full bg-text-muted" />
        {article.focusKeyword && <span>{article.focusKeyword}</span>}
      </div>

      <h1 itemprop="headline" class="mt-3 font-display text-3xl md:text-4xl font-bold text-text-primary leading-tight tracking-tight">
        {article.title}
      </h1>

      <p class="mt-4 text-base md:text-lg text-text-secondary leading-relaxed">
        {article.description}
      </p>

      <div class="mt-5 flex items-center gap-3 text-xs font-mono text-text-muted">
        <span itemprop="author">{author}</span>
        <span>·</span>
        <time itemprop="datePublished" datetime={article.datePublished}>
          {new Date(article.datePublished).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {article.dateModified !== article.datePublished && (
          <>
            <span>· Updated</span>
            <time itemprop="dateModified" datetime={article.dateModified}>
              {new Date(article.dateModified).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </>
        )}
      </div>
    </header>

    {/* ── Body ─────────────────────────────────────────────────────────────── */}
    <div class="space-y-0 [&_h2]:mt-12 [&_h2]:mb-4 [&_h3]:mt-8 [&_h3]:mb-3 [&_p]:mt-4 [&_ul]:mt-4 [&_ol]:mt-4 [&_li]:leading-relaxed">
      <PortableText value={article.body} components={ptComponents} />
    </div>

    {/* ── FAQs ─────────────────────────────────────────────────────────────── */}
    {article.faqs && article.faqs.length > 0 && (
      <section class="mt-16">
        <h2 class="font-display text-2xl font-bold text-text-primary leading-tight tracking-tight mb-6">
          Frequently asked questions
        </h2>
        <div class="space-y-7">
          {article.faqs.map((faq: any) => (
            <div>
              <h3 class="font-display text-lg font-semibold text-text-primary">{faq.question}</h3>
              <p class="mt-2 text-text-secondary leading-relaxed">{faq.answer}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    {/* ── Newsletter ───────────────────────────────────────────────────────── */}
    <div class="mt-16">
      <NewsletterSignup
        client:visible
        source={`newsletter-guide-${slug}`}
        title="Get the monthly State of GEO report"
        detail="AI search readiness benchmarks, adoption stats, and the actions that move the needle — delivered monthly. No spam."
      />
    </div>
  </article>

  {/* ── Structured data ──────────────────────────────────────────────────────── */}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Shell>
