---
import Shell from '../components/Shell.astro';
---

<Shell title="Research — GEO Optimizer">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-3xl md:text-4xl font-bold">Research</h1>
    <p class="mt-4 text-text-secondary">
      GEO Optimizer is built on peer-reviewed research and industry reports.
    </p>

    <div class="mt-10 space-y-4">
      <div class="p-5 rounded-lg border border-border bg-bg-surface">
        <h3 class="font-display font-semibold">Princeton KDD 2024</h3>
        <p class="mt-1 text-sm text-text-secondary">
          Foundations of Generative Engine Optimization: what signals LLMs use to cite sources.
        </p>
      </div>
      <div class="p-5 rounded-lg border border-border bg-bg-surface">
        <h3 class="font-display font-semibold">AutoGEO ICLR 2026</h3>
        <p class="mt-1 text-sm text-text-secondary">
          Automated GEO optimization pipelines and evaluation metrics.
        </p>
      </div>
      <div class="p-5 rounded-lg border border-border bg-bg-surface">
        <h3 class="font-display font-semibold">SE Ranking 2025</h3>
        <p class="mt-1 text-sm text-text-secondary">
          Industry analysis of AI search visibility factors and ranking signals.
        </p>
      </div>
    </div>
  </section>
</Shell>
