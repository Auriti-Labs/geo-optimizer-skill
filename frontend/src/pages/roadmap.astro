---
import Shell from '../components/Shell.astro';
---

<Shell title="Roadmap — GEO Optimizer">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-3xl md:text-4xl font-bold">Roadmap</h1>
    <p class="mt-4 text-text-secondary">Where GEO Optimizer is heading. No dates, just direction.</p>

    <div class="mt-10 space-y-6">
      <div class="p-6 rounded-xl border-l-4 border-accent-success bg-bg-surface border border-border">
        <h2 class="font-display font-semibold">Now</h2>
        <ul class="mt-3 space-y-2 text-sm text-text-secondary">
          <li>Visual audit dashboard with radar charts</li>
          <li>Scheduled monitoring with trend tracking</li>
          <li>REST API for third-party integrations</li>
          <li>Prompt injection detection</li>
        </ul>
      </div>

      <div class="p-6 rounded-xl border-l-4 border-accent-teal bg-bg-surface border border-border">
        <h2 class="font-display font-semibold">Next</h2>
        <ul class="mt-3 space-y-2 text-sm text-text-secondary">
          <li>WordPress plugin with admin dashboard</li>
          <li>Server log analysis for AI crawler activity</li>
          <li>Multi-site batch audit with CSV export</li>
          <li>Competitor comparison reports</li>
        </ul>
      </div>

      <div class="p-6 rounded-xl border-l-4 border-text-muted bg-bg-surface border border-border">
        <h2 class="font-display font-semibold">Later</h2>
        <ul class="mt-3 space-y-2 text-sm text-text-secondary">
          <li>WebMCP agent-readiness audit</li>
          <li>Topical cluster architecture analysis</li>
          <li>Trust Stack signal aggregation</li>
          <li>Multi-language GEO optimization</li>
        </ul>
      </div>
    </div>
  </section>
</Shell>
