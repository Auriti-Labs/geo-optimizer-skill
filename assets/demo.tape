# VHS tape — regenerate with: vhs assets/demo.tape
# https://github.com/charmbracelet/vhs

Output assets/demo.gif

Set FontSize 15
Set Width 1000
Set Height 560
Set Theme "Catppuccin Mocha"
Set TypingSpeed 40ms
Set Padding 12

Type "uvx --from geo-optimizer-skill geo audit --url https://geoready.dev --format rich"
Sleep 600ms
Enter
Sleep 14s
Type "# Score, band, and prioritized fixes — in one command."
Sleep 3s
